# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELETHON_BOT_TOKEN=your_telethon_bot_token_here

# Telethon StringSessions (REQUIRED to avoid SQLite lock issues)
# Generate with: python3 generate_bot_session.py
BOT_SESSION_STRING=your_bot_session_string_here
TELETHON_SESSION_STRING=your_user_session_string_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Telegram API Configuration for Telethon
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Airtable Configuration
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_base_id_here
AIRTABLE_TABLE_ID=your_table_id_here

# Google Sheets Configuration
GOOGLE_SHEETS_ID=your_sheets_id_here
SLA_GOOGLE_SHEETS_ID=your_sla_sheets_id_here
